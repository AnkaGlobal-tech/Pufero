<div
  id="anka-loyalty-root"
  aria-live="polite"
  data-locale="{{ localization.language.iso_code | default: request.locale.iso_code | default: 'en' }}"
  data-currency="{{ cart.currency.iso_code | default: shop.currency }}"
></div>
{{ 'anka-widget.css' | asset_url | stylesheet_tag }}
<script src="{{ 'anka-widget.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Anka Loyalty",
  "target": "body",
  "settings": [
    {
      "type": "paragraph",
      "content": "Renk, konum, dil ve metinler Anka Loyalty admin → Görünüm bölümünden yönetilir."
    }
  ]
}
{% endschema %}
