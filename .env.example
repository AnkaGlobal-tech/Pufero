# --- Shopify (Partner hesabı açılınca doldurulacak) ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SCOPES=write_products

# --- Supabase ---
# Dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Dashboard -> Database -> Connect -> Transaction pooler -> URI
# Ornek: postgresql://postgres.PROJECT_REF:SIFRE@aws-1-eu-central-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# --- Sentry ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- Session storage (Prisma + SQLite; Gün 3'te Supabase Postgres'e taşınacak) ---
DATABASE_URL=file:dev.sqlite
